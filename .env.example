# ── LLM ──────────────────────────────────────────────────────────────────────
SENTISTREAM_LLM_MODEL=gpt-4o-mini
SENTISTREAM_LLM_API_KEY=your_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
SENTISTREAM_POSTGRES_DSN=postgresql+asyncpg://sentistream:password@postgres:5432/sentistream
SENTISTREAM_REDIS_URL=redis://redis:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Comma-separated list. Inside Docker use kafka:29092; local dev use localhost:9092
SENTISTREAM_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ── ML / HuggingFace ──────────────────────────────────────────────────────────
SENTISTREAM_HF_REPO_ID=your_username/sentistream-encoder-v4
SENTISTREAM_EMBEDDER_DIR=/app/models/bge-small
SENTISTREAM_UMAP_PATH=/app/models/umap/model.onnx

# ── DBStream tuning (optional overrides) ──────────────────────────────────────
# SENTISTREAM_DBSTREAM_CLUSTERING_THRESHOLD=1.06
# SENTISTREAM_DBSTREAM_FADING_FACTOR=0.05
# SENTISTREAM_DBSTREAM_CLEANUP_INTERVAL=2.0
# SENTISTREAM_DBSTREAM_INTERSECTION_FACTOR=0.3
# SENTISTREAM_DBSTREAM_MINIMUM_WEIGHT=1.0
